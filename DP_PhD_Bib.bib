@Article{GarciaSanchez2019,
  author       = {Garcia-Sanchez, Jose Rafael and Hernandez-Marquez, Eduardo and Ramirez-Morales, Jesus and Marciano-Melchor, Magdalena and Marcelino-Aranda, Mariana and Taud, Hind and Silva-Ortigoza, Ramon},
  date         = {2019},
