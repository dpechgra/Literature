@InProceedings{Wu2024,
  author    = {Wu, Chao and Ren, Bin and Liang, Huijian and Xue, Jingjing and Chen, Xiang and Li, Haike and Huo, Xingyu},
  booktitle = {Advanced Fiber Laser Conference (AFL2023)},
  date      = {2024-03},
  title     = {Research on MEMS fast steering mirror technology requirements for space optical communication system},
  doi       = {10.1117/12.3023600},
  editor    = {Zhou, Pu},
  number    = {are},
  pages     = {302},
  publisher = {SPIE},
  abstract  = {Miniaturization and low-cost laser communication terminal is the development direction of space payload. MEMS fast steering mirrors (FSM) has the characteristics of small size, low power consumption, large deflection angle, high closedloop control bandwidth and low cost. It is a potential fast steering mirror to realize the miniaturized laser communication terminal beam high-precision scanning and pointing, and is also one of the development directions of low SWaP-C laser communication terminal technology. For space laser communication terminal pointing acquisition and tracking (PAT) system, the optical and mechanical characteristics of MEMS fast steering mirror used in beam deflection mechanism are analyzed in combination with theory and engineering application. According to the quasi-static working mode of MEMS fast steering mirror for fine pointing assembly (FPA) and point ahead angle (PAA) mechanism and the resonant working mode for nutation coherent tracking mechanism, the static and dynamic plane types, working bandwidth and scanning angle, closed-loop control accuracy, volume, weight, power consumption and reliability requirements of MEMS fast steering mirror are analyzed in detail. The technical parameters of MEMS FSM for space laser communication are presented, which can provide reference for its application in space laser communication system.},
  file      = {:PDF/Wu2024.pdf:PDF},
  groups    = {FSM Technology/Applications},
  keywords  = {MEMS fast steering mirror, pointing acquisition and tracking, optical and mechanical characteristics},
}

@InProceedings{Pfund2025,
  author    = {Pfund, Johannes and Brock, Christian and Pfeifer, Lucas and Reitberger, Thomas and Neuwirth, Daniel and Binder, Johannes and Hoenicka, Reinhold},
  booktitle = {Optical Sensing and Precision Metrology},
  date      = {2025-03},
  title     = {Characterization of fast steering mirrors for free space communication},
  doi       = {10.1117/12.3039007},
  editor    = {Scheuer, Jacob},
  pages     = {26},
  publisher = {SPIE},
  abstract  = {The low orbit of Earth is currently experiencing a surge in the number of small cube-satellites, the majority of which are utilised for communication purposes. Initially, these satellites were linked via radio frequency (RF) connections, but in recent times, optical links utilising lasers have become the norm due to their superior data transmission rates. But how can the laser on one cube-sat be consistently directed towards another, while both satellites orbit around earth? This is made possible by a fast steering mirror, which is able to redirect the laser beam with high frequency and accuracy. It enables the correction of vibrations and of micro-movements of the satellite as well as adjustments that consider the time of flight of the laser light. The distance between the sending and receiving cube-sats is typically several thousand kilometres. Any deformations of the fast steering mirror's surface shape will directly imprint on the wavefront of the reflected laser beam, which in turn will increase the laser beam diameter due to propagation along the entire path from sending to receiving cube-sats. This will reduce the quality of the data transmission. This paper presents a discussion and comparison of two different measurement approaches for the qualification of the surface flatness of the fast steering mirror, deflectometry and wavefront sensor respectively. These two technologies are complementary in this application and both offer high accuracy at lambda/10 ptv or better for flat mirror testing. While deflectometry generally offers a higher lateral resolution, wavefront sensors measure at a higher speed and in single shot. The analysis encompasses measurements of the influence of the fast movement and corresponding acceleration on the fast steering mirror's surface shape aberrations. Furthermore, we discuss the behaviour under normal ambient conditions as well as in vacuum conditions.},
  file      = {:C\:/Users/dani_/Documents/GitHub/PhD/06_Literatur/Dual Stage Actuation/PDF/Pfund2025.pdf:PDF},
  groups    = {FSM Technology/Applications},
  keywords  = {Free space communication, Fast steering mirrors, Wavefront testing, Surface shape measurement, Phase shifting deflectometry},
}

@InProceedings{Betsch2024,
  author    = {Betsch, Etienne and Bedek, Augustin and Bourgeot, Nicolas and Barnique, Arnaud and Meneroud, Patrick and Grardel, Hugo and Person- Nat, Pierre and Simon, Théo and Fournier, Marc and Chardon, Sylvain and Aigouy, Gérald and De Lepine, Xavier and Claeyssen, Frank},
  date      = {2024},
  title     = {Magnetic Fast Steering Mirror for Inter-satellites and Feeder Link Optical Communication},
  publisher = {IEEE},
  abstract  = {In order to cope with performances of Fine Pointing, and Fast Steering mirror requirements for Space Optical Communication, CEDRAT TECHNOLOGIES (CTEC) is developing magnetic Fast Steering Mirror's (M-FSM) family, based on proprietary MICA™ flexure bearing magnetic actuators mechanism (Moving Iron Controllable Actuator), with embedded eddy current sensors (ECS). FSM design expected for Optical Inter-Satellite Link (OISL) in large-scale New Space constellations, is highly driven by mandatory cost-efficiency for high quantities recurrent production, while FSM design expected for Feeder-Link communication is driven instead by high power Laser requirements together with high level of redundancy. In this publication CTEC is presenting both the M-FSM45 and M-FSM-HPL designs, and test results, respectively for inter-satellites and feeder link optical communications.},
